package cftest

fn main() -> i64 {
    let mut total: i64 = 0;
    let mut i: i64 = 0;
    while (i < 10) {
        if (i == 5) {
            i = i + 1;
            continue;
        }
        if (i == 8) {
            break;
        }
        total = total + i;
        i = i + 1;
    }

    for (let mut j: i64 = 0; j < 5; j = j + 1) {
        if (j == 3) {
            break;
        }
        total = total + j;
    }

    return total;
}
