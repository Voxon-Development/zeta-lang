package zeta::utils::array_list;

import zeta::libc;

extern(C) func println_int(num: i32);

struct ArrayList<T> {
    ptr: [*]mut T,
    len: usize,
    cap: usize,
}

impl<T> ArrayList<T> {
    func new(): ArrayList<T> {
        return ArrayList<T> {
            ptr: null,
            len: 0,
            cap: 0
        };
    }

    func len(&this): usize {
        return this.len;
    }

    func push(&mut this, value: T) {
        if (this.ptr == null || this.len == this.cap) {
            this.grow();
        }

        this.ptr[this.len] = value;
        this.len += 1;
    }

    func get(&this, index: usize): &T {
        if (index >= this.len) {
            panic "out of bounds";
        }
        return &this.ptr[index];
    }

    func get_mut(&mut this, index: usize): &mut T {
        if (index >= this.len) {
            panic "out of bounds";
        }
        return &mut this.ptr[index];
    }

    func grow(&mut this) {
        let new_cap: usize =
            if (this.cap == 0) {
                16
            } else {
                this.cap * 2
            };

        let new_ptr: [*]mut T = libc.malloc(new_cap * $sizeof<T>()) as [*]mut T;

        for (let mut i: usize = 0; i < this.len; i += 1) {
            new_ptr[i] = this.ptr[i];
        }

        if (this.ptr != null) {
            free(this.ptr as [*]mut void);
        }

        this.ptr = new_ptr;
        this.cap = new_cap;
    }
}

impl<T> ArrayList<T> by Drop {
    func drop(mut this) {
        if (this.ptr != null) {
            libc.free(this.ptr as [*]mut void);
        }
    }
}
