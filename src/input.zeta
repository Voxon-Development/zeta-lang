extern(C) fn get_index() -> i64;
extern(C) fn println_long(num: i64);

fn main() {
    let mut arr: [4]i64 = [1, 2, 3, 4];

    let index: i64 = get_index();
    if (index == 2) {
        let a: &mut i64 = &mut arr[index];
        let b: &mut i64 = &mut arr[1];

        *a = 10;
        *b = 20;
        println_long(*a);
        println_long(*b);
    }
}
