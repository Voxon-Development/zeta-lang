package zeta::input;

public struct Resource { id: i64 }
impl Resource by Drop {
    fn drop(mut this) -> void {
        zeta::repro.println_str("dropping Resource");
    }
}

fn consume(r: Resource) -> void {
    zeta::repro.println_int(r.id);
}

fn main() {
    let r: Resource = Resource { id: 1 };
    consume(r);
    consume(r);
}
